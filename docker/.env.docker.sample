# ===============================================================
# CanvasHub Docker 环境变量
# ===============================================================
#
# Docker 是独立部署模式，与桌面封装/热更新/后端 drain+restart
# 是不同的更新模型。此文件仅用于 docker-compose 部署。
#
# 使用方式：
#   cp .env.docker.sample .env
#   # 编辑 .env 填入需要的值
#   docker compose up -d
#
# 全部可省略，settings.docker.json 有安全默认值。
# ===============================================================

# ─── 访问密码 ──────────────────────────────────────────────────
# 控制台访问密码。建议修改。
MINIAPP_ACCESS_PASSWORD=docker

# ─── Telegram ──────────────────────────────────────────────────
# 用于 Telegram 机器人通知。后端读取 CHAT_ID（不是 TELEGRAM_CHAT_ID）。
# TELEGRAM_BOT_TOKEN=
# CHAT_ID=

# ─── ChatGPT 账号池（Sidecar）───
# 主服务与 sidecar 之间的鉴权 key。留空则 entrypoint 自动生成一致值。
# CHATGPT_POOL_AUTH_KEY=

# ─── 图片生成提供商 ─────────────────────────────────────────────
# 至少配一个才能生成图片。

# Codex OAuth（优先推荐）
# CODEX_API_AUTH_FILE=data/managed_codex_oauth/auth.json
# CODEX_API_BASE=https://chatgpt.com/backend-api/codex

# 第三方 GPT 图片 API（OpenAI 兼容接口）
# THIRD_PARTY_IMAGE_API_KEY=
# THIRD_PARTY_IMAGE_API_BASE_URL=

# Google Gemini
# GOOGLE_API_KEY=
# GOOGLE_API_BASE_URL=

# Nano Banana（兼容接口）
# NANO_BANANA_API_KEY=
# NANO_BANANA_API_BASE_URL=

# ─── ComfyUI ─────────────────────────────────────────────────
# 指向你的 ComfyUI 实例地址。
# COMFY_BASE_URL=http://host.docker.internal:8188

# ─── Prompt 优化 ──────────────────────────────────────────────
# SPELL_API_KEY=
# SPELL_API_URL=
# PROMPT_SKILL_PROVIDER=gpt_oauth

# ─── 高级 ──────────────────────────────────────────────────────
# MAX_CONCURRENT_TASKS=3
# COMFY_TASK_TIMEOUT_SECONDS=1800
